    "props": ["flipper_left", "flipper_right", "pool_ball_1"],
    "gravityZones": [{ "id": "gravity-main", "width": 80, "height": 160, "forceX": 0, "forceY": 1000, "placement": { "anchor": "playfield.center" } }],
    "pickups": [
        {
            "id": "paddleL",
            "prop": "flipper_left",
            "at": { "u": 0.35, "v": 0.85 },
            "button": { "u": 0.06, "v": 0.96, "trigger": "flipper" }
        },
        {
            "id": "paddleR",
            "prop": "flipper_right",
            "at": { "u": 0.65, "v": 0.85 },
            "button": { "u": 0.94, "v": 0.96, "trigger": "flipper" }
        },
        { "id": "ball", "prop": "pool_ball_1", "at": { "u": 0.5, "v": 0.15 } }
    ],
    "link": { "groupField": "sandboxGroupId" },
    "spawn": ["arena.clear", "arena.walls", "gravityZones", "pickups"]
}
